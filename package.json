{
  "name": "akodemy",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "cd client && npm run dev",
    "server": "cd server && npm run dev",
    "seed": "cd server && node seed.js",
    "sync-exercism-tests": "node server/scripts/syncExercismTests.js",
    "sync-exercism-templates": "node server/scripts/syncExercismTemplates.js",
    "install-all": "npm install && cd client && npm install && cd ../server && npm install",
    "build:prod": "cd client && npm run build",
    "start:prod": "node server/production.js"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "html2canvas": "^1.4.1",
    "nodemailer": "^7.0.12",
    "xlsx": "^0.18.5"
  }
}
